# Example recall registry entry for code search backed by ripgrep.
# Copy into your recall config and update --root for your local checkout.
providers {
  id: "code"
  enabled: true
  weight: 1.0
  timeout_ms: 5000
  default_limit: 50
  stdio {
    command: "recall-ripgrep-provider"
    args: "--root"
    args: "/path/to/repo"
  }
}

# Optional: open grouped source labels at this provider block in your editor.
openers {
  id: "provider-config-editor"
  kinds: "provider_config"
  target_types: "file"
  command: "editor"
  args: "+{line}:{column}"
  args: "{path}"
}
