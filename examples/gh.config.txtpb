# Example recall registry entry for GitHub search through the gh CLI.
# GitHub search is selector-hinted: use recall -s github:file:content, github:pr:content, etc.
providers {
  id: "github"
  enabled: true
  weight: 1.0
  timeout_ms: 8000
  default_limit: 30
  transports {
    stdio {
      command: "recall-gh-provider"
    }
  }
}
